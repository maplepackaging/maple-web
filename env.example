# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Groq AI API Key
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Sanity CMS
# Create project at https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-api-token

# Revalidation Secret
# Generate a random secret for cache invalidation API
# Example: openssl rand -base64 32
REVALIDATION_SECRET=your-random-secret-key-here
